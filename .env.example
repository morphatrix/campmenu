# Copy to .env and adjust. Used by docker-compose.yml (env interpolation).
# Everything here has a sane default in docker-compose.yml; override what you need.

# --- Database (PostgreSQL container) ---
POSTGRES_USER=campmenu
POSTGRES_PASSWORD=campmenu
POSTGRES_DB=campmenu

# --- Public URLs / CORS ---
# Public URL of the frontend (used in invite/confirmation links).
APP_URL=http://localhost:5173
# Allowed browser origins (comma-separated). localhost is always allowed.
CORS_ORIGINS=http://localhost:5173
# Browser-facing API origin for the frontend. Leave the compose default unless
# you serve the API on a different host.
VITE_API_URL=http://localhost:8080

# --- Security ---
# CHANGE THIS: JWT signing secret, >= 32 random chars (openssl rand -base64 48).
JWT_SECRET=change-me-please-32-chars-min
# Optional: encrypts sensitive settings at rest (SMTP/DB password).
# Empty = plaintext. Generate with: openssl rand -base64 32
SETTINGS_ENC_KEY=

# --- First admin (created on first start if no admin exists) ---
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=changeme-strong-password
BOOTSTRAP_ADMIN_NAME=Admin

# --- Email ---
# false = new accounts are auto-confirmed (handy without an SMTP server).
EMAIL_CONFIRM_REQUIRED=false
# Leave SMTP_HOST empty to log emails to stdout instead of sending them.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@campmenu.local

# --- Branding ---
SITE_NAME=CampMenu
